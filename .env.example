# Copy to .env for local development. On Render, set these in the service Environment tab.

SECRET_KEY=change-me-to-a-long-random-string
DEBUG=true
ALLOWED_HOSTS=127.0.0.1,localhost

# Postgres (local or Supabase connection string)
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DATABASE

# Supabase S3-compatible storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
S3_ENDPOINT_URL=
AWS_S3_REGION_NAME=us-east-1

# Stripe (optional for local)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Production on Render (optional overrides)
# SECURE_SSL_REDIRECT=true
# CSRF_TRUSTED_ORIGINS=https://your-app.onrender.com
# RENDER_EXTERNAL_URL and RENDER_EXTERNAL_HOSTNAME are set automatically by Render
